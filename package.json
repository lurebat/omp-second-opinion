{
  "name": "omp-second-opinion",
  "version": "1.0.0",
  "description": "Independent, cross-family adversarial second-opinion review tool for oh-my-pi.",
  "type": "module",
  "license": "MIT",
  "files": [
    "index.ts",
    "core.ts",
    "prompts.ts",
    "types.ts",
    "README.md",
    "LICENSE",
    "scripts/dev-install.ts"
  ],
  "keywords": [
    "oh-my-pi",
    "omp",
    "extension",
    "second-opinion",
    "ai-review"
  ],
  "homepage": "https://github.com/lurebat/omp-second-opinion#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lurebat/omp-second-opinion.git"
  },
  "bugs": {
    "url": "https://github.com/lurebat/omp-second-opinion/issues"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "build": "bun build ./index.ts --target=node --format=esm --outdir=./.tmp-build",
    "dev-install": "bun scripts/dev-install.ts"
  },
  "devDependencies": {
    "@types/node": "latest",
    "bun-types": "latest",
    "typescript": "latest"
  },
  "omp": {
    "extensions": ["./index.ts"]
  }
}
